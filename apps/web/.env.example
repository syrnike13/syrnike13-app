# Справка по публичным client env.
# Реальные профили Vite лежат в apps/web/env/.
# apps/web/.env.local намеренно не используется проектом:
# dev/prod не должны случайно попадать в desktop package.
#
# Продакшен-бэкенд syrnike13.ru (используется явным pnpm web:dev:prod)
# VITE_API_URL=https://syrnike13.ru/api
# VITE_WS_URL=wss://syrnike13.ru/ws
# VITE_MEDIA_URL=https://syrnike13.ru/autumn
# VITE_PROXY_URL=https://syrnike13.ru/january

VITE_APP_TITLE=syrnike13
VITE_HCAPTCHA_SITEKEY=
# LiveKit-нода для голоса (по умолчанию берётся из GET / → features.livekit.nodes)
# VITE_VOICE_NODE=worldwide
# Отправка voice debug payloads в локальный debug-agent включается явно.
# VITE_VOICE_DEBUG_AGENT=true
