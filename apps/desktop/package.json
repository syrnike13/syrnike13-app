{
  "name": "@syrnike13/desktop",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build:hotkey-helper": "node scripts/build-hotkey-helper-win.mjs",
    "build:native-voice": "node scripts/build-native-voice-win.mjs",
    "build:shell": "pnpm --filter @syrnike13/platform build && tsup && pnpm run build:hotkey-helper && pnpm run build:native-voice",
    "postinstall": "node scripts/ensure-electron-path.mjs",
    "predev": "node scripts/ensure-electron-path.mjs",
    "prestart": "node scripts/ensure-electron-path.mjs",
    "dev": "pnpm run build:shell && concurrently -k -n web,electron \"pnpm --filter @syrnike13/web dev\" \"wait-on http-get://127.0.0.1:3000 && pnpm exec electron .\"",
    "build": "pnpm --filter @syrnike13/web build && pnpm run build:shell",
    "start": "pnpm exec electron .",
    "test": "vitest run",
    "package": "pnpm run build && electron-builder --publish never",
    "typecheck": "pnpm --filter @syrnike13/platform build && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@syrnike13/platform": "workspace:*",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@syrnike13/web": "workspace:*",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ru.syrnike13.desktop",
    "productName": "syrnike13",
    "protocols": [
      {
        "name": "syrnike13",
        "schemes": [
          "syrnike13"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "out/native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://syrnike13.ru/downloads/desktop/"
    },
    "nsis": {
      "differentialPackage": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
