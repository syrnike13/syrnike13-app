{
  "name": "@syrnike13/desktop",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build:native-runtime": "pnpm --filter @syrnike13/desktop-native build",
    "build:shell": "pnpm --filter @syrnike13/platform build && pnpm run build:native-runtime && tsup",
    "postinstall": "node scripts/ensure-electron-path.mjs",
    "predev": "node scripts/ensure-electron-path.mjs",
    "prestart": "node scripts/ensure-electron-path.mjs",
    "dev": "pnpm run dev:nightly",
    "dev:nightly": "node scripts/run-dev-channel.mjs nightly",
    "dev:prod": "node scripts/run-dev-channel.mjs prod",
    "dev:local": "node scripts/run-dev-channel.mjs local",
    "verify:web-dist": "node scripts/verify-web-dist-production.mjs",
    "build": "pnpm --filter @syrnike13/web build && pnpm run verify:web-dist && pnpm run build:shell",
    "start": "pnpm exec electron .",
    "test": "vitest run",
    "package": "pnpm run build && pnpm run package:prepared",
    "package:nightly": "pnpm run build && pnpm run package:prepared",
    "package:prepared": "electron-builder --config electron-builder.config.cjs --publish never && node scripts/verify-native-package.mjs",
    "upload:debug-artifacts": "node scripts/upload-debug-artifacts.mjs",
    "typecheck": "pnpm --filter @syrnike13/platform build && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@syrnike13/platform": "workspace:*",
    "@sentry/electron": "^7.15.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@syrnike13/web": "workspace:*",
    "@sentry/cli": "^3.6.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "electron": "43.1.0",
    "electron-builder": "^25.1.8",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
