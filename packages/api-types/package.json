{
  "name": "@syrnike13/api-types",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "generate": "openapi-typescript OpenAPI.json -o src/schema.ts && node scripts/write-type-aliases.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "openapi-typescript": "^5.4.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
